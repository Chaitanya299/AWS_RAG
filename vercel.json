{
  "version": 2,
  "builds": [
    {
      "src": "src/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/main.py"
    },
    {
      "src": "/docs",
      "dest": "src/main.py"
    },
    {
      "src": "/openapi.json",
      "dest": "src/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
